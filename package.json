{
  "name": "n8n-nodes-mautic-v7",
  "version": "1.0.1",
  "description": "Enhanced n8n node for Mautic 7 compatibility with comprehensive API coverage including tags, campaigns, and advanced management",
  "keywords": [
    "n8n",
    "n8n-nodes",
    "mautic",
    "mautic7",
    "marketing-automation"
  ],
  "license": "MIT",
  "author": {
    "name": "BSO GmbH",
    "email": "mailing@bso-gmbh.de"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bsogmbh/n8n-nodes-mautic-v7.git"
  },
  "homepage": "https://github.com/bsogmbh/n8n-nodes-mautic-v7#readme",
  "bugs": {
    "url": "https://github.com/bsogmbh/n8n-nodes-mautic-v7/issues"
  },
  "main": "dist/nodes/MauticAdvanced/MauticAdvanced.node.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier --write nodes credentials",
    "lint": "eslint nodes credentials --ext .js,.ts",
    "lint:fix": "eslint nodes credentials --ext .js,.ts --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MauticAdvancedApi.credentials.js",
      "dist/credentials/MauticAdvancedOAuth2Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/MauticAdvanced/MauticAdvanced.node.js",
      "dist/nodes/MauticAdvanced/MauticAdvancedTrigger.node.js",
      "dist/nodes/MauticAdvanced/MauticAdvancedAiTools.node.js",
      "dist/nodes/MauticAdvanced/MauticOAuthTest.node.js"
    ]
  },
  "devDependencies": {
    "@types/express": "^4.17.6",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "eslint-plugin-prettier": "^5.5.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.70.0",
    "prettier": "^3.2.5",
    "rimraf": "^3.0.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "@types/change-case": "^0.0.30",
    "change-case": "^5.4.4",
    "zod": "^3.22.0"
  }
}
